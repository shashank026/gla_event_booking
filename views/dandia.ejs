<%- include('layout', { title: 'Dandia Night | Booking' , bodyClass: 'page-dandia' , extraCss: '/css/dandia.css' , body:
  ` <section class="booking-section">
  <div class="container">
    <div class="ticket-card">
      <h2>Reserve your ticket | Dandia Night</h2>

      <p class="muted">
        Booking link expires in
        <span id="countdown" data-expires="${expiresAt}">--:--</span>
      </p>

      <form class="booking-form" onsubmit="return false;">
        <label>
          <span>Full name</span>
          <input type="text" name="name" placeholder="Your name" required />
        </label>

        <label>
          <span>Phone number</span>
          <input type="tel" name="phoneNumber" value="${phoneNumber}" readonly />
        </label>

        <div class="verify-fields">
          <p class="verify-heading">Student verification</p>

          <label>
            <span>Student ID / Roll number</span>
            <input type="text" name="rollNumber" placeholder="e.g. 2201100123" required />
          </label>

          <label>
            <span>College email ID</span>
            <input type="email" name="collegeEmail" placeholder="yourname@gla.ac.in" pattern=".+@gla\\.ac\\.in$"
              required />
          </label>

          <p class="field-hint">
            Use your official @gla.ac.in email. You'll need your student ID card at entry.
          </p>
        </div>

        <label>
          <span>Ticket type</span>
          <select name="tier">
            <option value="early" data-price="499">Early Bird &mdash; &#8377;499</option>
            <option value="regular" data-price="799">Regular &mdash; &#8377;799</option>
            <option value="vip" data-price="1499">VIP (front row) &mdash; &#8377;1499</option>
          </select>
        </label>

        <label>
          <span>Number of tickets</span>
          <input type="number" name="qty" min="1" max="10" value="1" />
        </label>

        <div class="inline-total">
          <span>Total</span>
          <strong id="inlineTotal">&#8377;499</strong>
        </div>

        <button type="button" class="btn whatsapp-btn">
          Pay via UPI
        </button>

        <p class="wa-note">
          We'll confirm your seats and take payment over WhatsApp.
        </p>
      </form>
    </div>
  </div>
  </section>

  <div class="sticky-book-bar">
    <div class="total-block">
      <span class="total-label">Total</span>
      <span class="total-amount" id="stickyTotal">&#8377;499</span>
    </div>

    <button type="button" class="whatsapp-btn">
      Pay via UPI
    </button>
  </div>

  <script src="/js/dandia.js"></script>
  <script src="/js/countdown.js"></script>
  `
  }) %>