<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="icon" href="/images/gla-university-logo.jpg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/styles.css" />
  <link rel="stylesheet" href="/css/header-footer.css" />
  <% if (typeof extraCss !== 'undefined') { %><link rel="stylesheet" href="<%= extraCss %>" /><% } %>
</head>
<body class="<%= typeof bodyClass !== 'undefined' ? bodyClass : '' %>">

  <header class="site-header">
    <div class="container header-inner">
      <a href="/" class="brand">
        <img src="/images/gla-university-logo.jpg" alt="GLA University" class="brand-logo" />
        <span class="brand-text">
          <strong>GLA University</strong>
          <small>Mathura &middot; Est. 2010</small>
        </span>
      </a>
      <nav class="site-nav">
        <a href="/">Home</a>
        <a href="#events">Events</a>
        <a href="https://gla.ac.in" target="_blank" rel="noopener">Student Portal</a>
      </nav>
    </div>
  </header>

  <div class="host-ribbon">
    <div class="container host-ribbon-inner">
      <img src="/images/gla-university-logo.jpg" alt="" class="host-ribbon-mark" />
      <span>An official GLA University student event</span>
    </div>
  </div>

  <main>
    <%- body %>
  </main>

  <footer class="site-footer">
    <div class="container footer-grid">
      <div class="footer-brand">
        <img src="/images/gla-university-logo.jpg" alt="GLA University" class="footer-logo" />
        <p>GLA University, 17 Km Stone, NH-2, Mathura-Delhi Road,<br />P.O. Chaumuhan, Mathura, Uttar Pradesh 281406</p>
        <p class="footer-legal">Established vide U.P. Act 21 of 2010.</p>
      </div>
      <div class="footer-links">
        <span class="footer-heading">Bookings</span>
        <a href="/">All events</a>
        <a href="#events">This event</a>
      </div>
      <div class="footer-links">
        <span class="footer-heading">Help</span>
        <a href="mailto:studentaffairs@gla.ac.in">studentaffairs@gla.ac.in</a>
        <a href="https://gla.ac.in" target="_blank" rel="noopener">gla.ac.in</a>
      </div>
    </div>
    <div class="container footer-bottom">
      <p>&copy; 2026 GLA University, Mathura. Tickets are for registered students only.</p>
    </div>
  </footer>
</body>
</html>
